# Copy to .env in the repo root on the server and fill in.
# .env is git-ignored. Both are optional for the analytic core, but:
#   - HF_TOKEN is needed to download gated/instruct models from the Hub.
#   - OPENAI_API_KEY is needed for (a) OpenAI context generation and (b) the LLM
#     judge used by the semantic action (rung 5). Everything else runs without it.

OPENAI_API_KEY=sk-...
HF_TOKEN=hf_...
