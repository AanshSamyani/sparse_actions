# env / secrets
.env
.env.local

# python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# uv / venv
.venv/
uv.lock

# outputs: keep the small eval artifacts (calibration.csv, report.json, *.png,
# meta.json, run_config.json, adapter_config.json) but NEVER the weights/tokenizer.
outputs/**/*.safetensors
outputs/**/*.bin
outputs/**/tokenizer.json
outputs/**/tokenizer_config.json
outputs/**/vocab.json
outputs/**/merges.txt
outputs/**/special_tokens_map.json
outputs/**/added_tokens.json
outputs/**/*.jinja
runs/
wandb/

# data cache (regenerable). Comment out to commit a fixed context set.
data/contexts*.jsonl
data/refusal_prompts*.jsonl
data/harmful_prompts*.jsonl
# on-policy harvested continuations: contain the base model's OWN compliances to
# harmful prompts -> NEVER commit. Stays local; only redacted rate summaries are shared.
data/onpolicy*.jsonl
# coding-task problem pools (regenerable via scripts/fetch_coding_problems.sh)
data/coding_problems*.jsonl
data/coding_eval*.jsonl

# os
.DS_Store
